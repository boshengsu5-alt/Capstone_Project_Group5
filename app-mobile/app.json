{
  "expo": {
    "name": "UniGear",
    "slug": "unigear-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#1E1B4B",
      "resizeMode": "contain"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.unigear.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "UniGear needs camera access to scan QR codes on equipment and take return condition photos.",
        "NSPhotoLibraryUsageDescription": "UniGear needs photo library access to upload damage report photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E1B4B"
      },
      "package": "com.unigear.mobile",
      "permissions": [
        "CAMERA",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "UniGear needs camera access to scan QR codes on equipment and take return condition photos."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "be12f5c2-9801-43f2-bb2e-4263039be757"
      }
    },
    "owner": "beausu"
  }
}
